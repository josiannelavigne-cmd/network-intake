%%{init: {'theme':'base', 'themeVariables': {'primaryColor':'#FFFFFF','primaryTextColor':'#1a1a1a','primaryBorderColor':'#555555','lineColor':'#888888','fontFamily':'Inter, Helvetica, Arial, sans-serif','fontSize':'14px'}}}%%
flowchart TB

%% =====================================================
%% CENTRAK 2.0 — END-TO-END WORKFLOW
%% Intake -> NIC -> Execution -> Close
%% Combined angles: process logic - personas - data sources
%% =====================================================

classDef confirmed fill:#E8F5E9,stroke:#2E7D32,stroke-width:1.5px,color:#1a1a1a
classDef toValidate fill:#FFF3E0,stroke:#E65100,stroke-width:1.5px,color:#1a1a1a
classDef decision fill:#E3F2FD,stroke:#1565C0,stroke-width:1.5px,color:#0d3a66
classDef dataSource fill:#F3E5F5,stroke:#6A1B9A,stroke-width:1.5px,color:#3d1252
classDef vpAction fill:#FCE4EC,stroke:#AD1457,stroke-width:1.5px,color:#5a0a31
classDef phaseTitle fill:#FAFAFA,stroke:#BBBBBB,stroke-width:1px,color:#555

%% ---------- LEGEND ----------
subgraph LEGEND["LEGEND"]
    direction LR
    L1[Confirmed step]:::confirmed
    L2[To validate with Bell]:::toValidate
    L3{Decision}:::decision
    L4[(Data source)]:::dataSource
    L5[VP action]:::vpAction
end

%% ---------- PHASE 1 : DOCUMENTATION ----------
subgraph PHASE1["PHASE 1 — BUSINESS CASE DOCUMENTATION | Actor: Project Prime / TPM"]
    direction TB
    P1[Initiative identified]:::confirmed
    P2["Create business case in Centrak<br/>NPBC module — Sections 1 to 6"]:::confirmed
    P3["1. Project info<br/>2. Executive summary<br/>3. Financial profile<br/>4. Benefits<br/>5. Security<br/>6. Architecture"]:::confirmed
    P4["Add collaborators<br/>Director prime · involved BUs"]:::confirmed
end

%% ---------- TRIAGE ----------
TRIAGE{"Funding available<br/>AND<br/>resources available?"}:::decision

%% ---------- PHASE 2A : NIC PATH ----------
subgraph PHASE2A["PHASE 2A — NIC APPROVAL | Funded path | Actors: NIC Primes + NIC Chair"]
    direction TB
    N1[Submit for NIC approval]:::confirmed
    N2["Notification to NIC Primes<br/>Finance · Architecture · Security · Network domains"]:::confirmed
    N3["Due diligence per section<br/>Level of concern (green/yellow/red)"]:::confirmed
    N4["Upload required files<br/>IVA · Finance files"]:::confirmed
    N5["NIC Chair schedules NIC call<br/>Generates draft email + deck"]:::confirmed
    N6{"Project > $5M?"}:::decision
    N7[Standard NIC approval]:::confirmed
    N8["Escalate to MERCO (President)<br/>via deck export"]:::confirmed
end

%% ---------- PHASE 2B : INTAKE PATH ----------
subgraph PHASE2B["PHASE 2B — INTAKE | Unfunded or no resources | Actor: Mae + committees"]
    direction TB
    I1[Submit for intake]:::toValidate
    I2["Mae receives submission<br/>Additional fields TBD"]:::toValidate
    I3[Review cycles]:::confirmed
    I4["Weekly review<br/>Senior Managers"]:::confirmed
    I5["Bi-weekly review<br/>Directors — Friday"]:::confirmed
    I6[VP escalation if needed]:::confirmed
    I7{Outcome}:::decision
    I8[Analysis]:::confirmed
    I9[POC]:::confirmed
    I10[Implementation approval]:::confirmed
end

%% ---------- PHASE 3 : VP REVIEW ----------
subgraph PHASE3["PHASE 3 — VP REVIEW | Actor: VPs (consultation only)"]
    direction TB
    V1["Review summary view<br/>4 key sections + indicators"]:::vpAction
    V2{VP decision}:::decision
    V3["Written approval<br/>Email or meeting minutes"]:::vpAction
    V4["Funding released<br/>by Finance"]:::vpAction
end

%% ---------- PHASE 4 : EXECUTION ----------
subgraph PHASE4["PHASE 4 — EXECUTION & TRACKING | Actors: TPM + Mae + Finance"]
    direction TB
    E1["TPM executes the initiative<br/>Jira Portfolio — ONWP prefix"]:::confirmed
    E2["Mae tracks plan vs actuals<br/>at PEATS level<br/>(not at initiative level)"]:::confirmed
    E3["Forecasting module<br/>Monthly tracking — YE forecast"]:::confirmed
    E4["LRP module<br/>2× per year — 3-year horizon<br/>(to redefine with Cloud team)"]:::toValidate
end

%% ---------- PHASE 5 : CLOSE ----------
PC["PHASE 5 — PEATS CLOSURE<br/>Closing documentation"]:::confirmed

%% ---------- DATA SOURCES ----------
subgraph DATA["INTEGRATED DATA SOURCES"]
    direction TB
    D1[("PEATS<br/>Wallets · corporate classification")]:::dataSource
    D2[("SAP<br/>Vendor contracts · actuals")]:::dataSource
    D3[("FDW — Finance Data Warehouse<br/>SAP + 3-day delay")]:::dataSource
    D4[("VP Management System<br/>Network APIs · priorities")]:::dataSource
    D5[("ServiceNow<br/>Security front door — future integration")]:::dataSource
    D6[("Jira Portfolio<br/>ONWP — execution")]:::dataSource
    D7[("Confluence<br/>LBC — current state")]:::dataSource
end

%% =====================================================
%% PROCESS FLOW (solid arrows)
%% =====================================================
P1 --> P2 --> P3 --> P4 --> TRIAGE
TRIAGE -- "Yes" --> N1
TRIAGE -- "No" --> I1
N1 --> N2 --> N3 --> N4 --> N5 --> N6
N6 -- "No" --> N7
N6 -- "Yes" --> N8
N7 --> V1
N8 --> V1
I1 --> I2 --> I3
I3 --> I4 --> I5 --> I6
I6 --> I7
I7 --> I8
I7 --> I9
I7 --> I10
I10 -. "If funding needed<br/>loop back to NIC" .-> N1
V1 --> V2
V2 -- "Approved" --> V3 --> V4
V2 -- "Rejected / to revise" --> P3
V4 --> E1
E1 --> E2
E2 --> E3
E2 --> E4
E3 --> PC
E4 --> PC

%% =====================================================
%% DATA FLOWS (dotted arrows)
%% =====================================================
D1 -. "Auto-pull classification<br/>PEATS number" .-> P2
D2 -. "Vendor dropdowns<br/>contracts" .-> P3
D2 -. "Financial actuals" .-> E2
D3 -. "Financial data<br/>3-day delay" .-> E3
D4 -. "Network priorities mapping" .-> P3
D5 -. "Security assessment<br/>(future)" .-> N3
D6 -. "Execution tracking" .-> E1
D7 -. "Current state<br/>to migrate to Centrak 2.0" .-> P2
